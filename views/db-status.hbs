<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KanbanPro - Estado BD</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f4f6f9; margin: 0; padding: 40px; }
    .container { max-width: 900px; margin: auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
    h1 { text-align: center; color: #2c3e50; }
    .status { padding: 25px; border-radius: 10px; margin: 20px 0; text-align: center; font-size: 1.2rem; }
    .success { background: #d4edda; color: #155724; border: 2px solid #c3e6cb; }
    .error { background: #f8d7da; color: #721c24; border: 2px solid #f5c6cb; }
    .info { background: #f8f9fa; padding: 20px; border-radius: 8px; }
    pre { background: #2c3e50; color: #fff; padding: 15px; border-radius: 8px; overflow-x: auto; }
    button { padding: 12px 25px; background: #3498db; color: white; border: none; border-radius: 6px; cursor: pointer; margin-top: 10px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>🔌 KanbanPro - Estado de la Base de Datos</h1>

    {{#if success}}
      <div class="status success">
        ✅ ¡Conexión Exitosa a PostgreSQL!
      </div>
    {{else}}
      <div class="status error">
        ❌ Error de Conexión
      </div>
      <p><strong>Error:</strong> {{error}}</p>
    {{/if}}

    <div class="info">
      <h3>Información de Conexión usada:</h3>
      <pre>
Usuario:     {{user}}
Host:        {{host}}
Base de datos: {{database}}
Puerto:      {{port}}
      </pre>
    </div>

    <a href="/"><button>Volver al Inicio</button></a>
    <a href="/db-status"><button>Intentar de nuevo</button></a>
  </div>
</body>
</html>